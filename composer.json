{
    "name": "rockberpro/rosa-router",
    "description": "Smart REST router for PHP",
    "license": "MIT",
    "config": {
        "platform": {
            "php": "8.4.1"
        }
    },
    "require": {
        "php": ">=8.4",
        "react/http": "^1.11",
        "monolog/monolog": "3.9",
        "symfony/http-foundation": "8.1",
        "symfony/dotenv": "8.0",
        "ext-json": "*",
        "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "Rockberpro\\RosaRouter\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "symfony/var-dumper": "^5.4"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text --coverage-html coverage/html"
    }
}
